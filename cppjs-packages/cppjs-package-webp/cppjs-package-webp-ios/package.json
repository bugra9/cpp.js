{
    "name": "@cpp.js/package-webp-ios",
    "version": "2.0.0-beta.26",
    "nativeVersion": "1.6.0",
    "description": "iOS build of the precompiled WebP image library, built with cpp.js. Use it together with the main package @cpp.js/package-webp.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-webp#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "BSD-3-Clause",
    "keywords": [
        "webp",
        "libwebp",
        "image",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-webp": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}