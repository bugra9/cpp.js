{
    "name": "@cpp.js/package-zlib-wasm",
    "version": "2.0.0-beta.29",
    "nativeVersion": "1.3.2",
    "description": "WebAssembly build of the precompiled zlib library, built with cpp.js. Use it together with the main package @cpp.js/package-zlib.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-zlib#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "Zlib",
    "type": "module",
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-zlib": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    },
    "keywords": [
        "zlib",
        "libz",
        "compression",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ]
}