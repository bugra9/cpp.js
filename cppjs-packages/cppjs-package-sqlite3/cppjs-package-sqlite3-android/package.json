{
    "name": "@cpp.js/package-sqlite3-android",
    "version": "2.0.0-beta.26",
    "nativeVersion": "3.53.2",
    "description": "Android build of the precompiled SQLite3 database engine, built with cpp.js. Use it together with the main package @cpp.js/package-sqlite3.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-sqlite3#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "blessing",
    "type": "module",
    "scripts": {
        "build": "cppjs build -p android",
        "clear": "rm -rf .cppjs dist",
        "prepublishOnly": "cppjs build -p android"
    },
    "dependencies": {
        "@cpp.js/package-sqlite3": "workspace:^",
        "@cpp.js/package-zlib-android": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    },
    "keywords": [
        "sqlite",
        "sqlite3",
        "libsqlite3",
