{
    "name": "@cpp.js/package-sqlite3-ios",
    "version": "2.0.0-beta.21",
    "nativeVersion": "3.53.2",
    "description": "iOS build of the precompiled SQLite3 database engine, built with cpp.js. Use it together with the main package @cpp.js/package-sqlite3.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-sqlite3#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "blessing",
    "type": "module",
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-sqlite3": "workspace:^",
        "@cpp.js/package-zlib-ios": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    },
    "keywords": [
        "sqlite",
        "sqlite3",
        "libsqlite3",
        "database",
        "sql",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ]
