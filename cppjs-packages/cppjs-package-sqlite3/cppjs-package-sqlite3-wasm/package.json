    "license": "blessing",
    "type": "module",
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-sqlite3": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
