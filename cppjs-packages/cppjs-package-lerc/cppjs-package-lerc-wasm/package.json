{
    "name": "@cpp.js/package-lerc-wasm",
    "version": "2.0.0-beta.29",
    "nativeVersion": "4.1.1",
    "description": "WebAssembly build of the precompiled LERC (Limited Error Raster Compression) library, built with cpp.js. Use it together with the main package @cpp.js/package-lerc.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/cppjs-packages/cppjs-package-lerc#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "Apache-2.0",
    "keywords": [
        "lerc",
        "libLerc",
        "raster-compression",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-lerc": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}