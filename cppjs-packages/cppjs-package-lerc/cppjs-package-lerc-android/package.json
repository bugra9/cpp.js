{
    "name": "@cpp.js/package-lerc-android",
    "version": "2.0.0-beta.24",
    "nativeVersion": "4.1.0",
    "description": "Android build of the precompiled LERC (Limited Error Raster Compression) library, built with cpp.js. Use it together with the main package @cpp.js/package-lerc.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/cppjs-packages/cppjs-package-lerc#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "Apache-2.0",
    "keywords": [
        "lerc",
        "libLerc",
        "raster-compression",
        "cpp.js",
        "cpp.js-package",
        "android",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p android",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p android",
        "build:android": "cppjs build -p android"
    },
    "dependencies": {
        "@cpp.js/package-lerc": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}