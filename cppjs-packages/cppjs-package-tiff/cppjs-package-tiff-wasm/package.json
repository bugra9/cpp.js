{
    "name": "@cpp.js/package-tiff-wasm",
    "version": "2.0.0-beta.29",
    "nativeVersion": "4.7.2",
    "description": "WebAssembly build of the precompiled TIFF (libtiff) image library, built with cpp.js. Use it together with the main package @cpp.js/package-tiff.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-tiff#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "libtiff",
    "keywords": [
        "tiff",
        "libtiff",
        "image",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-tiff": "workspace:^",
        "@cpp.js/package-zlib-wasm": "workspace:^",
        "@cpp.js/package-jpegturbo-wasm": "workspace:^",
        "@cpp.js/package-zstd-wasm": "workspace:^",
        "@cpp.js/package-lerc-wasm": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}
