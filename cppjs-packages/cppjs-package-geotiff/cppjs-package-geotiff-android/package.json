{
    "name": "@cpp.js/package-geotiff-android",
    "version": "2.0.0-beta.21",
    "nativeVersion": "1.7.4",
    "description": "Android build of the precompiled libgeotiff (GeoTIFF) library, built with cpp.js. Use it together with the main package @cpp.js/package-geotiff.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-geotiff#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "geotiff",
        "libgeotiff",
        "gis",
        "geospatial",
        "cpp.js",
        "cpp.js-package",
        "android",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p android",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p android",
        "build:android": "cppjs build -p android"
    },
    "dependencies": {
        "@cpp.js/package-geotiff": "workspace:^",
        "@cpp.js/package-proj-android": "workspace:^",
        "@cpp.js/package-tiff-android": "workspace:^",
        "@cpp.js/package-zlib-android": "workspace:^",
        "@cpp.js/package-jpegturbo-android": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}