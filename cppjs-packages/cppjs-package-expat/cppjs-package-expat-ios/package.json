{
    "name": "@cpp.js/package-expat-ios",
    "version": "2.0.0-beta.24",
    "nativeVersion": "2.8.1",
    "description": "iOS build of the precompiled Expat XML parser library, built with cpp.js. Use it together with the main package @cpp.js/package-expat.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-expat#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "expat",
        "libexpat",
        "xml",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-expat": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}