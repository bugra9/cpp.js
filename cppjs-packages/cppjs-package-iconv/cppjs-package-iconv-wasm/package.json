{
    "name": "@cpp.js/package-iconv-wasm",
    "version": "2.0.0-beta.21",
    "nativeVersion": "1.19",
    "description": "WebAssembly build of the precompiled libiconv character-encoding library, built with cpp.js. Use it together with the main package @cpp.js/package-iconv.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-iconv#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "LGPL",
    "keywords": [
        "iconv",
        "libiconv",
        "charset",
        "encoding",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-iconv": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}