{
    "name": "@cpp.js/package-iconv-ios",
    "version": "2.0.0-beta.23",
    "nativeVersion": "1.19",
    "description": "iOS build of the precompiled libiconv character-encoding library, built with cpp.js. Use it together with the main package @cpp.js/package-iconv.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-iconv#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "LGPL-2.1-or-later",
    "keywords": [
        "iconv",
        "libiconv",
        "charset",
        "encoding",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-iconv": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}