{
    "name": "@cpp.js/package-proj-wasm",
    "version": "2.0.0-beta.31",
    "nativeVersion": "9.8.1",
    "description": "WebAssembly build of the precompiled PROJ coordinate-transformation library, built with cpp.js. Use it together with the main package @cpp.js/package-proj.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-proj#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "proj",
        "libproj",
        "projection",
        "gis",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-proj": "workspace:^",
        "@cpp.js/package-tiff-wasm": "workspace:^",
        "@cpp.js/package-sqlite3-wasm": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}