{
    "name": "@cpp.js/package-proj-ios",
    "version": "2.0.0-beta.29",
    "nativeVersion": "9.8.1",
    "description": "iOS build of the precompiled PROJ coordinate-transformation library, built with cpp.js. Use it together with the main package @cpp.js/package-proj.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-proj#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "proj",
        "libproj",
        "projection",
        "gis",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-proj": "workspace:^",
        "@cpp.js/package-tiff-ios": "workspace:^",
        "@cpp.js/package-sqlite3-ios": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}