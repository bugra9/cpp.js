{
    "name": "@cpp.js/package-gdal-wasm",
    "version": "2.0.0-beta.24",
    "nativeVersion": "3.13.1",
    "description": "WebAssembly build of the precompiled GDAL geospatial library, built with cpp.js. Use it together with the main package @cpp.js/package-gdal.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-gdal#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "gdal",
        "libgdal",
        "gis",
        "geospatial",
        "raster",
        "vector",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-gdal": "workspace:^",
        "@cpp.js/package-curl-wasm": "workspace:^",
        "@cpp.js/package-expat-wasm": "workspace:^",
        "@cpp.js/package-geos-wasm": "workspace:^",
        "@cpp.js/package-geotiff-wasm": "workspace:^",
        "@cpp.js/package-iconv-wasm": "workspace:^",
        "@cpp.js/package-jpegturbo-wasm": "workspace:^",
        "@cpp.js/package-proj-wasm": "workspace:^",
        "@cpp.js/package-spatialite-wasm": "workspace:^",
        "@cpp.js/package-sqlite3-wasm": "workspace:^",
        "@cpp.js/package-tiff-wasm": "workspace:^",
        "@cpp.js/package-webp-wasm": "workspace:^",
        "@cpp.js/package-zlib-wasm": "workspace:^",
        "@cpp.js/package-zstd-wasm": "workspace:^",
        "@cpp.js/package-lerc-wasm": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}
