{
    "name": "@cpp.js/package-gdal-ios",
    "version": "2.0.0-beta.23",
    "nativeVersion": "3.13.1",
    "description": "iOS build of the precompiled GDAL geospatial library, built with cpp.js. Use it together with the main package @cpp.js/package-gdal.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-gdal#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "gdal",
        "libgdal",
        "gis",
        "geospatial",
        "raster",
        "vector",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-gdal": "workspace:^",
        "@cpp.js/package-curl-ios": "workspace:^",
        "@cpp.js/package-expat-ios": "workspace:^",
        "@cpp.js/package-geos-ios": "workspace:^",
        "@cpp.js/package-geotiff-ios": "workspace:^",
        "@cpp.js/package-iconv-ios": "workspace:^",
        "@cpp.js/package-jpegturbo-ios": "workspace:^",
        "@cpp.js/package-proj-ios": "workspace:^",
        "@cpp.js/package-spatialite-ios": "workspace:^",
        "@cpp.js/package-sqlite3-ios": "workspace:^",
        "@cpp.js/package-tiff-ios": "workspace:^",
        "@cpp.js/package-webp-ios": "workspace:^",
        "@cpp.js/package-zlib-ios": "workspace:^",
        "@cpp.js/package-zstd-ios": "workspace:^",
        "@cpp.js/package-lerc-ios": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}
