{
    "name": "@cpp.js/package-gdal-android",
    "version": "2.0.0-beta.26",
    "nativeVersion": "3.13.1",
    "description": "Android build of the precompiled GDAL geospatial library, built with cpp.js. Use it together with the main package @cpp.js/package-gdal.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-gdal#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "gdal",
        "libgdal",
        "gis",
        "geospatial",
        "raster",
        "vector",
        "cpp.js",
        "cpp.js-package",
        "android",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p android",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p android",
        "build:android": "cppjs build -p android"
    },
    "dependencies": {
        "@cpp.js/package-gdal": "workspace:^",
        "@cpp.js/package-curl-android": "workspace:^",
        "@cpp.js/package-expat-android": "workspace:^",
        "@cpp.js/package-geos-android": "workspace:^",
        "@cpp.js/package-geotiff-android": "workspace:^",
        "@cpp.js/package-iconv-android": "workspace:^",
        "@cpp.js/package-jpegturbo-android": "workspace:^",
        "@cpp.js/package-proj-android": "workspace:^",
        "@cpp.js/package-spatialite-android": "workspace:^",
        "@cpp.js/package-sqlite3-android": "workspace:^",
        "@cpp.js/package-tiff-android": "workspace:^",
        "@cpp.js/package-webp-android": "workspace:^",
        "@cpp.js/package-zlib-android": "workspace:^",
        "@cpp.js/package-zstd-android": "workspace:^",
        "@cpp.js/package-lerc-android": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}
