{
    "name": "@cpp.js/package-zstd-android",
    "version": "2.0.0-beta.23",
    "nativeVersion": "1.5.7",
    "description": "Android build of the precompiled Zstandard (zstd) library, built with cpp.js. Use it together with the main package @cpp.js/package-zstd.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/cppjs-packages/cppjs-package-zstd#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "BSD-3-Clause",
    "keywords": [
        "zstd",
        "zstandard",
        "libzstd",
        "compression",
        "cpp.js",
        "cpp.js-package",
        "android",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p android",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p android",
        "build:android": "cppjs build -p android"
    },
    "dependencies": {
        "@cpp.js/package-zstd": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}