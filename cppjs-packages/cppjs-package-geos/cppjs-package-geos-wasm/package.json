{
    "name": "@cpp.js/package-geos-wasm",
    "version": "2.0.0-beta.23",
    "nativeVersion": "3.14.1",
    "description": "WebAssembly build of the precompiled GEOS geometry library, built with cpp.js. Use it together with the main package @cpp.js/package-geos.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-geos#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "LGPL-2.1-or-later",
    "keywords": [
        "geos",
        "libgeos",
        "geometry",
        "gis",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-geos": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}