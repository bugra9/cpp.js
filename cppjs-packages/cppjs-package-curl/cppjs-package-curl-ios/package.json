{
    "name": "@cpp.js/package-curl-ios",
    "version": "2.0.0-beta.26",
    "nativeVersion": "8.21.0",
    "description": "iOS build of the precompiled libcurl (CURL) library, built with cpp.js. Use it together with the main package @cpp.js/package-curl.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-curl#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "curl",
    "keywords": [
        "curl",
        "libcurl",
        "http",
        "networking",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-curl": "workspace:^",
        "@cpp.js/package-openssl-ios": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}