{
    "name": "@cpp.js/package-curl-wasm",
    "version": "2.0.0-beta.21",
    "nativeVersion": "8.20.0",
    "description": "WebAssembly build of the precompiled libcurl (CURL) library, built with cpp.js. Use it together with the main package @cpp.js/package-curl.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-curl#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "curl",
    "keywords": [
        "curl",
        "libcurl",
        "http",
        "networking",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-curl": "workspace:^",
        "@cpp.js/package-openssl-wasm": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}