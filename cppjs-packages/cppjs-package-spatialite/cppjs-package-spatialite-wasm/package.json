{
    "name": "@cpp.js/package-spatialite-wasm",
    "version": "2.0.0-beta.26",
    "nativeVersion": "5.1.0",
    "description": "WebAssembly build of the precompiled SpatiaLite (spatial SQLite extension) library, built with cpp.js. Use it together with the main package @cpp.js/package-spatialite.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-spatialite#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MPL-1.1 OR GPL-2.0-or-later OR LGPL-2.1-or-later",
    "keywords": [
        "spatialite",
        "libspatialite",
        "sqlite",
        "spatial",
        "gis",
        "cpp.js",
        "cpp.js-package",
        "webassembly",
        "wasm"
    ],
    "scripts": {
        "build": "cppjs build -p wasm",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p wasm"
    },
    "dependencies": {
        "@cpp.js/package-spatialite": "workspace:^",
        "@cpp.js/package-geos-wasm": "workspace:^",
        "@cpp.js/package-proj-wasm": "workspace:^",
        "@cpp.js/package-sqlite3-wasm": "workspace:^",
        "@cpp.js/package-zlib-wasm": "workspace:^",
        "@cpp.js/package-iconv-wasm": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}