{
    "name": "@cpp.js/package-spatialite-ios",
    "version": "2.0.0-beta.24",
    "nativeVersion": "5.1.0",
    "description": "iOS build of the precompiled SpatiaLite (spatial SQLite extension) library, built with cpp.js. Use it together with the main package @cpp.js/package-spatialite.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-package-spatialite#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "type": "module",
    "license": "MPL-1.1 OR GPL-2.0-or-later OR LGPL-2.1-or-later",
    "keywords": [
        "spatialite",
        "libspatialite",
        "sqlite",
        "spatial",
        "gis",
        "cpp.js",
        "cpp.js-package",
        "ios",
        "react-native"
    ],
    "scripts": {
        "build": "cppjs build -p ios",
        "clear": "rm -rf .cppjs dist *.xcframework",
        "prepublishOnly": "cppjs build -p ios"
    },
    "dependencies": {
        "@cpp.js/package-spatialite": "workspace:^",
        "@cpp.js/package-geos-ios": "workspace:^",
        "@cpp.js/package-proj-ios": "workspace:^",
        "@cpp.js/package-sqlite3-ios": "workspace:^",
        "@cpp.js/package-zlib-ios": "workspace:^",
        "@cpp.js/package-iconv-ios": "workspace:^"
    },
    "devDependencies": {
        "cpp.js": "workspace:^"
    }
}