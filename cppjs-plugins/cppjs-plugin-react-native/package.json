{
    "name": "@cpp.js/plugin-react-native",
    "version": "2.0.0-beta.26",
    "description": "Cpp.js React Native plugin: A tool for seamless C++ integration with React Native and Expo.",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-plugin-react-native#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "MIT",
    "main": "js/index.js",
    "type": "module",
    "codegenConfig": {
        "name": "RNCppjsSpec",
        "type": "modules",
        "jsSrcsDir": "spec",
        "android": {
            "javaPackageName": "com.jsi.lib"
        }
    },
    "peerDependencies": {
        "react-native": "*",
        "metro": "*",
        "@expo/config-plugins": "*"
    },
    "peerDependenciesMeta": {
        "@expo/config-plugins": {
            "optional": true
        }
    },
    "dependencies": {
        "cpp.js": "workspace:^",
        "@cpp.js/plugin-metro": "workspace:^",
        "@cpp.js/core-embind-jsi": "workspace:^",
        "@babel/runtime": "^7.29.7",
        "upath": "^3.0.7"
    },
    "keywords": [
        "cpp.js-plugin",
        "react-native",
        "expo",
        "bind",
        "c++",
        "android",
        "ios",
        "mobile"
    ]
}