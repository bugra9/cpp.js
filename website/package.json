{
  "name": "@cpp.js/website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "sync:agent-docs": "node scripts/sync-agent-docs.mjs",
    "build:llms-full": "node scripts/build-llms-full.mjs",
    "prestart": "pnpm run sync:agent-docs && pnpm run build:llms-full",
    "start": "docusaurus start",
    "prebuild": "pnpm run sync:agent-docs && pnpm run build:llms-full",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "check:links": "remark --frail --use remark-lint-no-dead-urls .",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "copy:readme": "find ../cppjs-packages -path \"../cppjs-packages/cppjs-package-*/cppjs-package-*/README.md\" -maxdepth 3 -exec bash -c 'src=\"{}\"; name=$(basename $(dirname \"$src\")); case \"$name\" in *-wasm|*-android|*-ios) exit 0;; esac; dest=\"./docs/package/package/${name}.md\"; cp \"$src\" \"$dest\"' \\;",
    "copy:changelog:core": "cp ../cppjs-core/cpp.js/CHANGELOG.md ./docs/changelog/core/cppjs.md; find ../cppjs-core -path \"../cppjs-core/cppjs-core-*/CHANGELOG.md\" -maxdepth 2 -exec bash -c 'src=\"{}\"; dest=\"./docs/changelog/core/$(basename $(dirname \"$src\")).md\"; cp \"$src\" \"$dest\"' \\;",
    "copy:changelog:plugin": "find ../cppjs-plugins -path \"../cppjs-plugins/cppjs-plugin-*/CHANGELOG.md\" -maxdepth 2 -exec bash -c 'src=\"{}\"; dest=\"./docs/changelog/plugins/$(basename $(dirname \"$src\")).md\"; cp \"$src\" \"$dest\"' \\;",
    "copy:changelog:package": "find ../cppjs-packages -path \"../cppjs-packages/cppjs-package-*/cppjs-package-*/CHANGELOG.md\" -maxdepth 3 -exec bash -c 'src=\"{}\"; name=$(basename $(dirname \"$src\")); case \"$name\" in *-wasm|*-android|*-ios) exit 0;; esac; dest=\"./docs/changelog/packages/${name}.md\"; cp \"$src\" \"$dest\"' \\;",
    "copy:changelog:sample": "find ../cppjs-samples -path \"../cppjs-samples/cppjs-sample-*/CHANGELOG.md\" -maxdepth 2 -exec bash -c 'src=\"{}\"; dest=\"./docs/changelog/samples/$(basename $(dirname \"$src\")).md\"; cp \"$src\" \"$dest\"' \\;",
    "copy": "pnpm run copy:readme && pnpm run copy:changelog:core && pnpm run copy:changelog:plugin && pnpm run copy:changelog:package && pnpm run copy:changelog:sample"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/remark-plugin-npm2yarn": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "postcss": "^8.5.10",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "@tailwindcss/postcss": "^4.2.4",
    "typescript": "^6.0.3",
    "remark-cli": "^12.0.1",
    "remark-lint-no-dead-urls": "^2.0.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}