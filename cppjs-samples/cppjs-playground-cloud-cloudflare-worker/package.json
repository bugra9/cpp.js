{
    "name": "@cpp.js/playground-cloud-cloudflare-worker",
    "version": "2.0.0-beta.23",
    "private": true,
    "description": "Cpp.js - Cloudflare webassembly playground",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-playground-cloud-cloudflare-worker#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "MIT",
    "scripts": {
        "build": "cppjs build -p wasm -e edge -r st",
        "dev": "wrangler dev",
        "deploy": "wrangler dev",
        "e2e:dev": "playwright test --config playwright.dev.config.cjs"
    },
    "files": [
        "dist/@cpp.js/sample-cloud-cloudflare.edge.js",
        "dist/@cpp.js/sample-cloud-cloudflare.edge.wasm",
        "index.js",
        "cppjs.config.mjs",
        "wrangler.toml",
        "src"
    ],
    "dependencies": {
        "cpp.js": "workspace:^",
        "@cpp.js/package-expat-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-gdal-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-geos-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-geotiff-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-iconv-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-openssl-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-proj-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-spatialite-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-sqlite3-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-tiff-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-webp-wasm": "^2.0.0-beta.29",
        "@cpp.js/package-zlib-wasm": "^2.0.0-beta.29"
    },
    "devDependencies": {
        "wrangler": "^4.95.0",
