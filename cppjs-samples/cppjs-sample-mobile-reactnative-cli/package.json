{
    "name": "@cpp.js/sample-mobile-reactnative-cli",
    "private": true,
    "version": "2.0.0-beta.24",
    "description": "Cpp.js React Native sample",
    "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-sample-mobile-reactnative-cli#readme",
    "repository": "https://github.com/bugra9/cpp.js.git",
    "license": "MIT",
    "scripts": {
        "android": "react-native run-android",
        "ios": "react-native run-ios",
        "lint": "eslint .",
        "start": "react-native start",
        "test": "jest",
        "run:android": "react-native run-android --no-packager --mode Release",
        "run:ios": "react-native run-ios --no-packager --mode Release",
        "maestro": "maestro test ./maestro.yaml",
        "e2e:ios": "pnpm run run:ios && pnpm run maestro",
        "e2e:android": "pnpm run run:android && pnpm run maestro"
    },
    "dependencies": {
        "@cpp.js/core-embind-jsi": "workspace:^",
        "@cpp.js/plugin-metro": "workspace:^",
        "@cpp.js/plugin-react-native": "workspace:^",
        "@cpp.js/plugin-react-native-ios-helper": "workspace:^",
        "@cpp.js/sample-lib-prebuilt-matrix": "workspace:^",
        "react": "19.2.3",
        "react-native": "0.85.3",
        "react-native-safe-area-context": "^5.8.0",
        "hermes-compiler": "*"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/runtime": "^7.29.7",
        "@react-native-community/cli": "20.1.3",
        "@react-native-community/cli-platform-android": "20.1.3",
        "@react-native-community/cli-platform-ios": "20.1.3",
        "@react-native/babel-preset": "0.85.3",
        "@react-native/codegen": "0.85.3",
        "@react-native/eslint-config": "0.85.3",
        "@react-native/jest-preset": "0.85.3",
        "@react-native/gradle-plugin": "0.85.3",
        "@react-native/metro-config": "0.85.3",
        "@react-native/typescript-config": "0.85.3",
        "@types/jest": "^29.5.13",
        "@types/react": "^19.2.15",
        "@types/react-test-renderer": "^19.1.0",
        "eslint": "^8.19.0",
        "jest": "^29.6.3",
        "prettier": "3.8.3",
        "react-test-renderer": "19.2.3",
        "typescript": "^5.8.3"
    },
    "engines": {
        "node": ">= 22.11.0"
    },
    "keywords": [
        "cpp.js-sample",
        "react-native",
        "bind",
        "c++",
        "android",
        "ios",
        "mobile"
    ]
}