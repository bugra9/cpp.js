{
  "name": "@cpp.js/sample-mobile-reactnative-expo",
  "private": true,
  "main": "expo-router/entry",
  "version": "2.0.0-beta.24",
  "description": "Cpp.js Expo sample",
  "homepage": "https://github.com/bugra9/cpp.js/tree/main/packages/cppjs-sample-mobile-reactnative-expo#readme",
  "repository": "https://github.com/bugra9/cpp.js.git",
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "run:ios": "expo run:ios --no-bundler --configuration Release",
    "run:android": "expo run:android --no-bundler --variant release",
    "maestro": "maestro test ./maestro.yaml",
    "e2e:ios": "npm run run:ios && npm run maestro",
    "e2e:android": "npm run run:android && npm run maestro"
  },
  "dependencies": {
    "@cpp.js/core-embind-jsi": "2.0.0-beta.24",
    "@cpp.js/plugin-metro": "2.0.0-beta.24",
    "@cpp.js/plugin-react-native": "2.0.0-beta.24",
    "@cpp.js/plugin-react-native-ios-helper": "2.0.0-beta.24",
    "@cpp.js/sample-lib-prebuilt-matrix": "2.0.0-beta.24",
    "hermes-compiler": "*",
    "expo": "^56.0.5",
    "expo-constants": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.12",
    "expo-router": "~56.2.7",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1",
    "replace": {
      "minimatch": "3.1.4"
    },
    "brace-expansion@5.0.5": "5.0.6"
  },
  "keywords": [
    "cpp.js-sample",
    "react-native",
    "expo",
    "bind",
    "c++",
    "android",
    "ios",
    "mobile"
  ]
