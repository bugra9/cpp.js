{
    "private": true,
    "scripts": {
        "build:packages": "pnpm --filter='@cpp.js/package-*' run build",
        "build:samples": "pnpm --filter='@cpp.js/sample-*' run build",
        "build:samples:lib": "pnpm --filter='@cpp.js/sample-lib-*' run build",
        "build:samples:lib:wasm": "pnpm --filter='@cpp.js/sample-lib-*' run build:wasm",
        "build:samples:lib:android": "pnpm --filter='@cpp.js/sample-lib-*' run build:android",
        "build:samples:lib:ios": "pnpm --filter='@cpp.js/sample-lib-*' run build:ios",
        "build:samples:wasm": "pnpm --filter='@cpp.js/sample-web-*' run build && pnpm --filter='@cpp.js/sample-cloud-*' run build && pnpm --filter='@cpp.js/sample-backend-*' run build && pnpm run build:samples:lib:wasm",
        "build:website": "pnpm --filter=@cpp.js/website run build",
        "build": "pnpm run build:packages && pnpm run build:samples",
        "clear:cache:samples": "rimraf -g 'cppjs-samples/cppjs-sample-*/.cppjs'",
        "clear:cache:packages": "rimraf -g 'cppjs-packages/cppjs-package-*/cppjs-package-*/.cppjs'",
        "clear:cache": "pnpm run clear:cache:samples && pnpm run clear:cache:packages",
        "clear:dist:samples": "rimraf -g 'cppjs-samples/cppjs-sample-*/dist' 'cppjs-samples/cppjs-sample-*/*.xcframework'",
        "clear:dist:packages": "rimraf -g 'cppjs-packages/cppjs-package-*/cppjs-package-*/dist' 'cppjs-packages/cppjs-package-*/cppjs-package-*/*.xcframework'",
        "clear:dist:packages:android": "rimraf -g 'cppjs-packages/cppjs-package-*/cppjs-package-*-android/dist'",
        "clear:dist": "pnpm run clear:dist:samples && pnpm run clear:dist:packages",
        "clear:pack": "rimraf -g 'cppjs-packages/cppjs-package-*/cppjs-package-*/*.tgz' 'cppjs-plugins/cppjs-plugin-*/*.tgz' 'cppjs-samples/cppjs-sample-*/*.tgz' 'cppjs-core/*/*.tgz'",
        "clear:samples": "pnpm run clear:cache:samples && pnpm run clear:dist:samples",
        "clear:packages": "pnpm run clear:cache:packages && pnpm run clear:dist:packages",
        "clear:packages:android": "pnpm run clear:cache:packages && pnpm run clear:dist:packages:android",
        "clear": "pnpm run clear:cache && pnpm run clear:dist && pnpm run clear:pack",
        "pack:list": "find cppjs-packages -name '*.tgz' -maxdepth 4 -type f",
        "ci:linux:build:package": "pnpm --filter=@cpp.js/package-zlib-* run build",
        "ci:linux:build": "pnpm run build:samples && pnpm run ci:linux:build:package",
        "ci:windows:build": "pnpm run build:samples:lib:wasm && pnpm run build:samples:lib:android && pnpm run ci:linux:build:package",
        "ci:ios:build:package": "pnpm --filter=@cpp.js/package-zlib-ios run build",
        "ci:macos:build": "pnpm run build:samples:lib:ios && pnpm run ci:ios:build:package",
        "e2e:dev": "pnpm -r --workspace-concurrency=1 e2e:dev",
        "e2e:prod": "pnpm -r --workspace-concurrency=1 e2e:prod",
        "e2e:ios": "pnpm -r --workspace-concurrency=1 e2e:ios",
        "e2e:android": "pnpm -r --workspace-concurrency=1 e2e:android",
        "e2e:mobile": "pnpm run e2e:ios && pnpm run e2e:android",
        "e2e": "pnpm run e2e:dev && pnpm run e2e:prod && pnpm run e2e:mobile",
        "publish:samples": "pnpm --filter='@cpp.js/sample-*' publish --no-git-checks",
        "publish:plugins": "pnpm --filter='@cpp.js/plugin-*' publish --no-git-checks",
        "publish:core": "pnpm --filter=cpp.js publish --no-git-checks",
        "publish:mcp": "pnpm --filter=@cpp.js/mcp publish --no-git-checks",
        "publish:all": "pnpm run publish:core && pnpm run publish:mcp && pnpm run publish:plugins && pnpm run publish:samples",
        "publish:changeset": "changeset publish",
        "publish:beta": "pnpm --filter='@cpp.js/*' publish --no-git-checks --tag beta --access public --report-summary",
        "check:dist": "node scripts/check-dist.js",
        "check:beta": "node scripts/check-beta-status.js",
        "check:deps": "node scripts/check-external-dependencies.js",
        "check:deps:strict": "node scripts/check-external-dependencies.js --check",
        "check:native": "node scripts/check-native-versions.js",
        "check:native:strict": "node scripts/check-native-versions.js --check",
        "check": "pnpm run check:dist && pnpm run check:deps:strict && pnpm run check:native:strict",
        "help": "node scripts/help.js",
        "doctor": "bash scripts/doctor.sh",
        "scaffold:package": "node scripts/scaffold-package.js",
        "test": "pnpm --filter cpp.js test",
        "test:watch": "pnpm --filter cpp.js test:watch",
        "test:coverage": "pnpm --filter cpp.js test:coverage"
    },
    "devDependencies": {
        "cpp.js": "workspace:^",
        "prettier": "^3.8.3",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "@playwright/test": "^1.59.1",
        "@changesets/cli": "^2.31.0",
        "rimraf": "^6.1.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@swc/core",
            "esbuild",
            "sharp",
            "unrs-resolver",
            "workerd"
        ],
        "overrides": {
            "@babel/helpers@7": "^7.26.10",
            "@babel/plugin-transform-modules-systemjs@7": "^7.29.4",
            "@babel/runtime@7": "^7.26.10",
            "@xmldom/xmldom@0.8": "^0.8.13",
            "ajv@6": "^6.14.0",
            "brace-expansion@1": "^1.1.13",
            "brace-expansion@2": "^2.0.3",
            "brace-expansion@5": "^5.0.6",
            "devalue@5": "^5.8.1",
            "esbuild@0": ">=0.25.0",
            "estree-util-value-to-estree@3": "^3.3.3",
            "fast-uri@3": "^3.1.2",
            "fast-xml-builder@1": "^1.1.7",
            "flatted@3": "^3.4.2",
            "hono@4": "^4.12.18",
            "image-size@1": "^1.2.1",
            "ip-address@10": "^10.1.1",
            "js-yaml@3": "^3.14.2",
            "lodash@4": "^4.18.0",
            "mdast-util-to-hast@13": "^13.2.1",
            "mermaid@11": "^11.15.0",
            "minimatch@3": "^3.1.4",
            "minimatch@9": "^9.0.7",
            "node-forge@1": "^1.4.0",
            "on-headers@1": "^1.1.0",
            "path-to-regexp@0.1": "^0.1.13",
            "picomatch@2": "^2.3.2",
            "picomatch@4": "^4.0.4",
            "postcss@8": "^8.5.10",
            "prismjs@1": "^1.30.0",
            "qs@6": "^6.15.2",
            "serialize-javascript": "^7.0.5",
            "svelte@5": "^5.55.7",
            "svgo@3": "^3.3.3",
            "undici@6": "^6.24.0",
            "uuid": "^11.1.1",
            "vite@6": "^6.4.2",
            "webpack@5": "^5.104.1",
            "webpack-dev-server@5": "^5.2.4",
            "ws@8": "^8.20.1",
            "yaml@2": "^2.8.3"
        }
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}